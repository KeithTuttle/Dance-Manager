# Copy to .env and fill in from your Clerk application (https://dashboard.clerk.com).
# Publishable key (pk_test_... in dev, pk_live_... in prod). Enables auth + tenant
# isolation. Leave unset for an open, unauthenticated dev app.
VITE_CLERK_PUBLISHABLE_KEY=

# Origin of the deployed API (no trailing slash), e.g. https://dancemanager-api.onrender.com.
# Leave unset in local dev — Vite proxies /api to the backend instead (see vite.config.ts).
VITE_API_URL=
