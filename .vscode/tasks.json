{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "client: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/client" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "group": "dev",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "api: run",
      "type": "shell",
      "command": "dotnet run",
      "options": { "cwd": "${workspaceFolder}/server/DanceManager.Api" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "group": "dev",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Start: client + API",
      "dependsOn": ["client: dev", "api: run"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}
